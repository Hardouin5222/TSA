DISABLE_REQUIRE_CHANGE_PW = 0

# PayTR iFrame credentials - never commit real secrets
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# TSA Flight Supplier Engine
# mock_supplier keeps local mock offers; bridge calls TSA_SUPPLIER_ENGINE_BASE_URL.
FLIGHT_PROVIDER_MODE=mock_supplier
TSA_SUPPLIER_ENGINE_MODE=mock
TSA_SUPPLIER_ENGINE_BASE_URL=http://127.0.0.1:8010
TSA_SUPPLIER_ENGINE_TIMEOUT=20

# In production this must be false unless provider-specific signature verification is implemented.
TSA_DISABLE_WEBHOOK_SIGNATURE_CHECK=true

# TSA Supplier Engine future live/sandbox supplier credentials
# Keep these empty until the corresponding supplier adapter is implemented and tested.
DUFFEL_API_TOKEN=

MYSTIFLY_USERNAME=
MYSTIFLY_PASSWORD=
MYSTIFLY_ACCOUNT_NUMBER=

BILETBANK_USERNAME=
BILETBANK_PASSWORD=
BILETBANK_AGENCY_CODE=

# TSA Flight Search Guard / Look-to-Book protection
TSA_SEARCH_GUARD_ENABLED=true
TSA_SEARCH_CACHE_TTL_SECONDS=900
TSA_SEARCH_RATE_LIMIT_PER_MINUTE=12
TSA_SEARCH_RATE_LIMIT_PER_HOUR=120
TSA_SEARCH_L2B_WARNING_RATIO=1200
TSA_SEARCH_L2B_BLOCK_RATIO=1450
TSA_SEARCH_LIVE_SUPPLIER_MODES=duffel_sandbox,biletbank_sandbox

